{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibe-design-arena.local/schemas/integrity-result.schema.json",
  "title": "Vibe Design Arena Integrity Result",
  "type": "object",
  "required": ["schemaVersion", "action", "status", "timestamp"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "action": {"enum": ["snapshot", "normalize-brief", "check-attributes", "verify-brief"]},
    "status": {"enum": ["PASS", "FAIL", "CHANGED"]},
    "timestamp": {"type": "string"},
    "details": {"type": "object"}
  }
}
